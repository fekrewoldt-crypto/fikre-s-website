# Supabase (required)
SUPABASE_URL=your-supabase-url-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
# REQUIRED for Google OAuth: the Supabase anon (public) key. NOT the service key.
# Service-role keys are rejected by Supabase for signInWithOAuth. Without this,
# GET /auth/google returns 500 with code=MISSING_SUPABASE_ANON_KEY.
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Encryption
DATA_ENC_KEY=your-64-char-hex-encryption-key-here

# Google OAuth (optional — enables "Sign in with Google")
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret-here

# AI Models (at least one needed)
# Model priority: Groq (primary) → NVIDIA (text + vision) → Ollama (local) → Demo (fallback)
GROQ_API_KEY=your-groq-api-key-here
NVIDIA_API_KEY=your-nvidia-api-key-here
VISION_API_KEY=your-nvidia-vision-api-key-here  # optional, for image analysis
VISTA3D_API_KEY=your-vista3d-api-key-here
VISTA3D_URL=your-remote-host-or-ngrok-url:5000

# Database Migration (run after deploying this version)
# Run db/migrations/003_user_profiles_role.sql in Supabase SQL Editor to:
# 1. Create user_profiles table with role column
# 2. Backpopulate existing users from auth.users
# 3. Add trigger preventing authenticated users from updating their own role
# This fixes the privilege escalation vulnerability where updateUser() could set role='admin'

# Rate limiting
RATE_LIMIT_WINDOW=1
RATE_LIMIT_MAX=20

# CORS — comma-separated list of origins allowed to call the API from a browser.
# REQUIRED in production. Without this every browser request gets 500
# "Internal server error" because the default allowlist is localhost-only.
# Server auto-allows the Vercel-injected URLs (VERCEL_URL etc.) as a safety net,
# but set this explicitly so production CORS does not depend on Vercel internals.
# Use '*' to allow any origin (not recommended).
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Server
PORT=3000
NODE_ENV=production